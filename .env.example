# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required for:
#   • AI conversation engine (GPT-4o-mini) — powers live call responses
#   • TTS audio preview endpoint (tts-1-hd)
#   • Better knowledge-base embeddings (optional, falls back to ONNX)
OPENAI_API_KEY=sk-...

# ── Twilio ────────────────────────────────────────────────────────────────────
# Required for real outbound phone calls.
# When absent the system runs in "simulated" mode — no actual dial-out.
#
# Get credentials at: https://console.twilio.com
# TWILIO_PHONE_NUMBER must be a Twilio-purchased number in E.164 format.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+14155552671

# ── Server ────────────────────────────────────────────────────────────────────
# Public URL used to build Twilio webhook callback URLs.
# In development:  expose with `ngrok http 8000` and paste the HTTPS URL here.
# In production:   set to your domain, e.g. https://api.callbank.io
SERVER_BASE_URL=http://localhost:8000

# ── Database ──────────────────────────────────────────────────────────────────
# DATABASE_URL=sqlite+aiosqlite:///./data/callbank.db   # default — no change needed

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
