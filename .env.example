# ── Ollama (self-hosted LLM) ──────────────────────────────────────────────────
# Powers the AI conversation engine during live calls.
# Run locally:   ollama serve && ollama pull llama3.2:3b
# In Docker:     pre-configured to http://ollama:11434 (see docker-compose.yml)
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ── Piper TTS (self-hosted, offline) ──────────────────────────────────────────
# Directory where Piper ONNX voice models are stored.
# Models (~50–100 MB each) are downloaded automatically on first use.
# In Docker: pre-configured to /app/data/piper_models (persisted volume).
PIPER_MODELS_DIR=./data/piper_models

# ── Twilio ────────────────────────────────────────────────────────────────────
# Required for real outbound phone calls.
# When absent the system runs in "simulated" mode — no actual dial-out.
# Get credentials at: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+14155552671

# ── Server ────────────────────────────────────────────────────────────────────
# Public URL used to build Twilio webhook callback URLs.
# In development: expose with `ngrok http 8000` and paste the HTTPS URL here.
# In production:  set to your domain, e.g. https://api.callbank.io
SERVER_BASE_URL=http://localhost:8000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
